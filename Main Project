import React, { Component } from 'react';
import { AppRegistry, Text, View, StyleSheet, Image, TextInput, ImageBackground, TouchableHighlight, Alert, Dimensions, ScrollView } from 'react-native';
import Constants from 'expo-constants';

let deviceHeight = Dimensions.get('window').height;
let deviceWidth = Dimensions.get('window').width;

export default class App extends Component {
    
    state = {
        firstPageDisplay: 'block',
        secondPageDisplay: 'none',
        thirdPageDisplay: 'none',
        customAmount: '',
        currentWater: 0,
        dailyGoal: 100,
        streakDays: 0,
    }
    
    handleFirstPagePress = () => this.setState(state => ({
        firstPageDisplay: 'block',
        secondPageDisplay: 'none',
        thirdPageDisplay: 'none',
    }));

    handleSecondPagePress = () => this.setState(state => ({
        firstPageDisplay: 'none',
        secondPageDisplay: 'block',
        thirdPageDisplay: 'none',
    }));

    handleThirdPagePress = () => this.setState(state => ({
        firstPageDisplay: 'none',
        secondPageDisplay: 'none',
        thirdPageDisplay: 'block',
    }));
    
    addWater = (amount) => {
        this.setState({
            currentWater: this.state.currentWater + amount,
        })
    }
    
    logCustomWater = () => {
        if (this.state.customAmount == '' || isNaN(this.state.customAmount)) {
            Alert.alert('Please enter a number');
        } else {
            this.setState({
                currentWater: this.state.currentWater + Number(this.state.customAmount),
                customAmount: '',
            })
        }
    }
    
    lowerGoal = () => {
        if (this.state.dailyGoal > 8) {
            this.setState({
                dailyGoal: this.state.dailyGoal - 8,
            })
        }
    }
    
    raiseGoal = () => {
        this.setState({
            dailyGoal: this.state.dailyGoal + 8,
        })
    }
    
    saveGoal = () => {
        Alert.alert('Goal saved!');
    }
    
    goToNextDay = () => {
        if (this.state.currentWater >= this.state.dailyGoal) {
            this.setState({
                streakDays: this.state.streakDays + 1,
                currentWater: 0,
                customAmount: '',
            })
        } else {
            this.setState({
                streakDays: 0,
                currentWater: 0,
                customAmount: '',
            })
        }
    }
    
    render() {
        let progressWidth = (this.state.currentWater / this.state.dailyGoal) * (3*(deviceWidth/5));
        
        if (progressWidth > 3*(deviceWidth/5)) {
            progressWidth = 3*(deviceWidth/5);
        }
        
        return (
            <View style={styles.container}>
                
                
                
                <View style={{ display: this.state.firstPageDisplay }}>
                    <View style={styles.homeContainer}>
                    
                        <View style={styles.progressCard}>
                            <Text style={styles.progressTitle}>
                                Todays Progress
                            </Text>
                            <Text style={styles.progressText}>
                                {this.state.currentWater} oz / {this.state.dailyGoal} oz
                            </Text>
                            <View style={styles.progressBarBackground}>
                                <View style={[styles.progressBarFill, { width: progressWidth }]}>
                                </View>
                            </View>
                        </View>
                        
                        <View style={styles.quickAddSection}>
                            <View style={styles.quickAddRow}>
                                <TouchableHighlight
                                    onPress={() => this.addWater(8)}
                                >
                                    <View style={styles.smallButton}>
                                        <Text style={styles.smallButtonText}>
                                            +8 oz
                                        </Text>
                                    </View>
                                </TouchableHighlight>
                                <TouchableHighlight
                                    onPress={() => this.addWater(16)}
                                >
                                    <View style={styles.smallButton}>
                                        <Text style={styles.smallButtonText}>
                                            +16 oz
                                        </Text>
                                    </View>
                                </TouchableHighlight>
                            </View>
                            
                            <View style={styles.quickAddRow}>
                                <TouchableHighlight
                                    onPress={() => this.addWater(24)}
                                >
                                    <View style={styles.smallButton}>
                                        <Text style={styles.smallButtonText}>
                                            +24 oz
                                        </Text>
                                    </View>
                                </TouchableHighlight>
                                <TouchableHighlight
                                    onPress={() => this.addWater(32)}
                                >
                                    <View style={styles.smallButton}>
                                        <Text style={styles.smallButtonText}>
                                            +32 oz
                                        </Text>
                                    </View>
                                </TouchableHighlight>
                            </View>
                        </View>
                        
                        <TextInput style={styles.textBox}
                            onChangeText={(customAmount) => this.setState({customAmount})}
                            value={this.state.customAmount}
                            placeholder='Custom'
                        />
                        
                        <TouchableHighlight
                            onPress={this.logCustomWater}
                        >
                            <View style={styles.bigButton}>
                                <Text style={styles.bigButtonText}>
                                    Log Custom Water
                                </Text>
                            </View>
                        </TouchableHighlight>
                    </View>
                </View>
                
                <View style={{ display: this.state.secondPageDisplay }}>
                    <View style={styles.streakContainer}>
                        <Text style={styles.sectionTitle}>
                            Your Streak
                        </Text>
                        
                        <Text style={styles.bigStreakText}>
                            {this.state.streakDays}
                        </Text>
                        <Text style={styles.streakText}>
                            days in a row
                        </Text>
                        <Text style={styles.streakMessage}>
                            Keep it up!
                        </Text>
                        
                        <View style={styles.weekRow}>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 1 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 2 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 3 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 4 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 5 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 6 ? '💧' : '⚪'}
                            </Text>
                            <Text style={styles.weekDrop}>
                                {this.state.streakDays >= 7 ? '💧' : '⚪'}
                            </Text>
                        </View>
                        
                        <TouchableHighlight
                            onPress={this.goToNextDay}
                        >
                            <View style={styles.bigButton}>
                                <Text style={styles.bigButtonText}>
                                    Next Day
                                </Text>
                            </View>
                        </TouchableHighlight>
                    </View>
                </View>
                
                
                
                <View style={{ display: this.state.thirdPageDisplay }}>
                    <View style={styles.goalContainer}>
                        <Text style={styles.sectionTitle}>
                            Daily Goal
                        </Text>
                        
                        <Text style={styles.goalAmount}>
                            {this.state.dailyGoal} oz
                        </Text>
                        
                        <View style={styles.goalButtonRow}>
                            <TouchableHighlight
                                onPress={this.lowerGoal}
                            >
                                <View style={styles.goalChangeButton}>
                                    <Text style={styles.goalChangeText}>
                                        -
                                    </Text>
                                </View>
                            </TouchableHighlight>
                            
                            <TouchableHighlight
                                onPress={this.raiseGoal}
                            >
                                <View style={styles.goalChangeButton}>
                                    <Text style={styles.goalChangeText}>
                                        +
                                    </Text>
                                </View>
                            </TouchableHighlight>
                        </View>
                        
                        
                    </View>
                </View>
                
                
                
                <View style={styles.bottomBar}>
                    <TouchableHighlight
                        onPress={this.handleFirstPagePress}
                    >
                        <View style={this.state.firstPageDisplay == 'block' ? styles.activeNavButton : styles.navButton}>
                            <Text style={this.state.firstPageDisplay == 'block' ? styles.activeNavText : styles.inactiveNavText}>
                                Home
                            </Text>
                        </View>
                    </TouchableHighlight>
                    
                    <TouchableHighlight
                        onPress={this.handleSecondPagePress}
                    >
                        <View style={this.state.secondPageDisplay == 'block' ? styles.activeNavButton : styles.navButton}>
                            <Text style={this.state.secondPageDisplay == 'block' ? styles.activeNavText : styles.inactiveNavText}>
                                Streak
                            </Text>
                        </View>
                    </TouchableHighlight>
                    
                    <TouchableHighlight
                        onPress={this.handleThirdPagePress}
                    >
                        <View style={this.state.thirdPageDisplay == 'block' ? styles.activeNavButton : styles.navButton}>
                            <Text style={this.state.thirdPageDisplay == 'block' ? styles.activeNavText : styles.inactiveNavText}>
                                Goal
                            </Text>
                        </View>
                    </TouchableHighlight>
                </View>
                
                
            </View>
            
            
      )
   }
}

